      },
      "dialog": {
        "start": {
          "text": "Psst... nicht so laut. Die Kaninchen mögen keine Fremden. Vor allem nicht, wenn sie laut sind!",
          "choices": [
            {
              "text": "Wer bist du?",
              "next": "vorstellung"
            },
            {
              "text": "Warum lebst du hier unten?",
              "next": "story"
            },
            {
              "text": "Okay... ich geh' wieder.",
              "next": null
            }
          ]
        },
        "vorstellung": {
          "text": "Ich bin Amina. Früher... naja, ich hatte große Pläne! Aber jetzt lebe ich hier bei den Kaninchen. Sie nennen mich Muck-Muck. Ich habe noch nicht herausgefunden, wofür das steht.",
          "next": "story"
        },
        "story": {
          "text": "Ich wollte eine Wolke fangen. Einfach so, aus dem Himmel reißen! Ganz für mich allein! Ich hatte sogar eine Harpune gebaut.\n\nSie hat nicht funktioniert.\nAlle haben gelacht.\n\nAlso bin ich hier runter. Die Kaninchen stellen keine Fragen.",
          "choices": [
            {
              "text": "Warum wolltest du eine Wolke fangen?",
              "next": "wolke"
            },
            {
              "text": "Du lebst jetzt echt bei Kaninchen?",
              "next": "kaninchen"
            },
            {
              "text": "Und die Harpune?",
              "next": "harpune"
            },
            {
              "text": "Okay… viel Glück noch.",
              "next": null
            }
          ]
        },
        "wolke": {
          "text": "Du bist schon mal kein Kaninchen. Du stellst Fragen.\n\nUm ehrlich zu sein: Ich dachte, wenn ich eine hätte... wäre endlich mal irgendwas anders.\nAlle schauen immer nach oben, aber die Leute, die unten sind, die sieht immer keiner.\nIch wollte, dass man sich an mich erinnert.",
          "next": "wolke1"
        },
        "wolke1": {
          "text": "Immerhin... eins habe ich erreicht. Die Leute erinnern sich an mich. Nur nicht so, wie ich wollte.",
          "next": "wunsch1"
        },
        "kaninchen": {
          "text": "Die sind erstaunlich organisiert. Sie verstecken alles.\n- Futter. Glitzerzeug. Gefühle.\nAber ihre Höhlen sind hart wie Stein.\n\nIch hab seit Tagen nicht richtig geschlafen...",
          "next": "wunsch1"
        },
        "harpune": {
          "text": "Die habe ich hier bei mir. Sie funktioniert theoretisch.\nPraktisch… na ja. Ich kann damit nicht umgehen. Es fiel mir schwer, alles zu koordinieren.\nHier unten brauche ich sie nicht mehr. Aber zum Wegschmeißen ist sie zu schade.",
          "next": "wunsch1"
        },
        "wunsch": {
          "text": "Wenn ich nur ein Kissen hätte...\nDann wäre das hier unten fast gemütlich.",
          "next": "start"
        },
        "wunsch1": {
          "text": "Wenn ich nur ein Kissen hätte...\nDann wäre das hier unten fast gemütlich.",
          "next": "story"
        },
        "tausch": {
          "text": "Ein Kissen...\nDas ist perfekt.\n\nHier. Nimm die Wolkenharpune.\nVielleicht klappt es ja bei dir besser als bei mir. \n\nOder du merkst rechtzeitig, dass Wolken nichts festhalten.",
          "trade": {
            "give": "kissen",
            "receive": "wolkenharpune"
          },
          "next": "nach_tausch"
        },
        "nach_tausch": {
          "text": "Jetzt ist es hier unten endlich weich.\n\nUnd du? Versuch nicht zu hoch zu zielen.",
          "next": null
        },
        "hat_kissen": {
          "text": "Du hast da ein Kissen...\nWillst du tauschen?",
          "next": null
        },
        "hat_schon_getauscht": {
          "text": "Die Harpune hast du ja schon.\n\nPass auf, dass du nicht auch unten landest wie ich.",
          "next": "start"
        },
        "falsch_item": {
          "text": "Das hilft mir hier unten nicht wirklich.",
          "next": null
        }
      }
    }
