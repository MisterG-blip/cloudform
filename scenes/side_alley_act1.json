  "npcs": {
    "scientist": {
      "name": "Dr. Timothy Schnurz",
      "portrait": "assets/npc/scientist_portrait.png",
      "entry": [
        {
          "node": "start"
        }
      ],
      "giveEntries": {
        "kissen": "tausch",
        "*": "falsch_item"
      },
      "dialog": {
        "start": {
          "text": "Guten Tag, wie kann ich dir helfen?",
          "choices": [
            {
              "text": "Wer sind Sie?",
              "next": "vorstellung"
            },
            {
              "text": "Warum stehen Sie vor der Tür?",
              "next": "story"
            },
            {
              "text": "Okay... ich geh wieder.",
              "next": null
            }
          ]
        },
        "start1": {
          "text": "Hast du eine andere Frage?",
          "choices": [
            {
              "text": "Wer sind Sie?",
              "next": "vorstellung"
            },
            {
              "text": "Warum stehen Sie vor der Tür?",
              "next": "story"
            },
            {
              "text": "Okay... ich geh wieder.",
              "next": null
            }
          ]
        },
        "vorstellung": {
          "text": "Ich bin Timothy Schnurz, Doktor der physikalisch-alchemistischen Chemie.",
          "next": "maybel"
        },
        "maybel": {
          "text": "Und mit wem habe ich es zu tun?",
          "choices": [
            {
              "text": "Ich bin Maybel, einige nannten mich auch mal die mächtige Maybel!",
              "next": "maybel1"
            },
            {
              "text": "Das geht Sie nichts an!",
              "next": "null"
            }            
          ]
        },
        "maybel1": {
          "text": "Und wonach suchst du?",
          "choices": [
            {
              "text": "Ich will eine Wolke haben! Ich habe mir eine gewünscht und jemand hat mir versprochen, dass ich sie auf diesem Wege bekomme.",
              "next": "maybel2"
            },
            {
              "text": "Das geht Sie nichts an!",
              "next": "null"
            }            
          ]
        },
        "maybel2": {
          "text": "Eine Wolke also...\nDas endet selten harmlos.\n\nSo einen Wunsch erfüllt man nicht mal eben.\nDa steckt meistens viel Arbeit dahinter.\n\nIch habe hier eine alte Pumpe abgestellt. Vielleicht hilft sie dir mehr als mir.\nAber es fehlen Teile.",
          "next": "start1"
        },        
        "story": {
          "text": "Unglücklicherweise befindet sich mein Schlüssel derzeit nicht mehr in meinem Besitz. Aber zum Glück weiß ich, wo der Schlüssel liegt: In meinem Labor auf der anderen Seite der Tür.",
          "choices": [
            {
              "text": "Was machen Sie in Ihrem Labor?",
              "next": "labor"
            },
            {
              "text": "Wieso ist Ihr Labor hier so versteckt?",
              "next": "labor1"
            },
            {
              "text": "Okay… viel Glück noch.",
              "next": null
            }
          ]
        },
        "story1": {
          "text": "Hast du noch eine Frage?",
          "choices": [
            {
              "text": "Was machen Sie in Ihrem Labor?",
              "next": "labor"
            },
            {
              "text": "Wieso ist Ihr Labor hier so versteckt?",
              "next": "labor1"
            },
            {
              "text": "Okay… viel Glück noch.",
              "next": null
            }
          ]
        },
        "labor": {
          "text": "Ich untersuche die physikalisch-alchemistische Chemie. Insbesondere interessieren mich die Zusammenhänge der Welt.\nWie entsteht Feuer?\nWoher kommt das Leben?\nWas ist die Seele der Materie?\nWas sind Wolken?",
          "choices": [
            {
              "text": "Wie entsteht Feuer?",
              "next": "feuer"
            },
            {
              "text": "Wie entsteht Leben?",
              "next": "leben"
            },
            {
              "text": "Was soll die Seele der Materie sein?",
              "next": "seele"
            },
            {
              "text": "Was sind Wolken?",
              "next": "wolke"
            },
            {
              "text": "Aha, danke",
              "next": "story1"
            }            
          ]          
        },
        "feuer": {
          "text": "Für die Verbrennung eines Stoffes wird Phlogiston benötigt. Ich habe schon mehrfach versucht, es nachzuweisen. Äußerst trickreich!\nIch vermute, man findet es in sehr heißen Objekten.\nMehr habe ich noch nicht herausgefunden.\nMöglicherweise brauchst du einen bestimmten Greifapparat.",
          "next": "labor"
        },
        "leben": {
          "text": "Wie natürliches Leben entsteht, solltest du wissen. Du bist alt genug.\nWie künstliches Leben entsteht, darüber lässt sich bislang nur spekulieren. Letztens bekam ich eine Phiole, aber ich habe sie noch nicht untersucht.",
          "next": "labor"
        },
        "seele": {
          "text": "Sulphorium nennt man die Seele der Materie, weil es auf Gedanken, Wärme und Leben zu reagieren scheint – fast, als wäre es lebendig.",
          "next": "labor"
        },
        "wolke": {
          "text": "Die meisten Menschen glauben, Wolken bestünden bloß aus Wasser. Das halte ich für eine außergewöhnlich langweilige Erklärung. Allerdings fehlen mir bislang valide Daten.\nDer erste Fehler liegt bereits darin, dass die Menschen die Wolken immer nur von unten betrachten. Früher wurde auf diesem Gebiet deutlich mehr geforscht.",
          "next": "labor"
        },
        "labor1": {
          "text": "Offiziell wird meine Forschung nicht unterstützt. Meine Kollegen meinen, sie sei nicht mehr zeitgemäß.\nDaher habe ich mein Labor hier eingemietet. Ich gönne mir diesen Luxus.\nHast du eine Spende?",
          "choices": [
            {
              "text": "Ich gucke, was ich finden kann.",
              "giveItem": "prismabrille",
              "next": "spende"
              
            },
            {
              "text": "Ich habe nichts zu verschenken.",
              "next": "story1"
            }            
          ]    
        },
        "spende": {
          "text": "Danke, immerhin hast du überlegt, wie du mir helfen könntest.",
          "next": "story1"
        }               
      }
    }
  }
}